{
  "name": "envsec-web",
  "version": "0.1.0",
  "description": "envsec web dashboard",
  "scripts": {
    "ng": "./node_modules/.bin/ng",
    "start": "bunx --bun ng serve",
    "build": "bunx --bun ng build",
    "build:prod": "bunx --bun ng build --configuration production",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "bunx --bun http-server dist/envsec-web/browser -p 4173 -c-1",
    "deploy": "bun run build:prod && firebase deploy --only hosting"
  },
  "private": true,
  "author": "shawal-mbalire",
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/node": "^24.10.1",
    "firebase-tools": "^13.0.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  }
}
