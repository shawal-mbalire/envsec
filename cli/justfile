# CLI module commands
# Run: just --justfile cli/justfile <command>

# Default: list commands
default:
    @just --list

# Build debug binary
build:
    cargo build

# Run tests
test:
    cargo test

# Build optimized release binary
release:
    cargo build --release

# Run clippy and fmt checks
lint:
    cargo clippy -- -D warnings
    cargo fmt --check

# Format code
fmt:
    cargo fmt

# Clean build artifacts
clean:
    cargo clean
